generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  name            String?
  bio             String?
  location        String?
  skills          String?
  qualification   String?
  department      String?
  passoutYear     String?
  experienceYears String?
  linkedinUrl     String?
  githubUrl       String?
  jobType         String?  @default("Remote")
  expectedSalary  String?
  profileComplete Boolean  @default(false)
}

model Job {
  id          String   @id @default(cuid())
  title       String
  company     String
  location    String
  description String
  experience  String
  salary      String
  applyUrl    String?
}